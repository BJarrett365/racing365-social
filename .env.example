# Dev server bind (optional). Default on macOS is :: (http://localhost + 127.0.0.1); elsewhere 0.0.0.0.
# Force IPv4-only: DEV_HOST=0.0.0.0  |  Loopback-only: DEV_HOST=127.0.0.1
# DEV_HOST=

# Dev file watching — `npm run dev` sets WATCHPACK_POLLING=true; next.config enables webpack poll(1s) unless disabled.
# WATCHPACK_POLLING=0
# NEXT_WEBPACK_POLL=0

# Admin UI (/admin) — required in production to POST saves; optional in development
# ADMIN_TOKEN=

# Plexa secure login. Required before public hosting.
# Generate with: openssl rand -base64 32
# PLEXA_SESSION_SECRET=
# Optional: protects first-admin setup in production.
# PLEXA_SETUP_TOKEN=
# Public host URL used when generating verification links, e.g. https://plexa.example.com
# PLEXA_PUBLIC_URL=

# Racing silks — proxy (recommended for Puppeteer + hotlink protection)
# Comma- or space-separated hostnames (no https://). Subdomains match: `timeform.com` allows `cdn.timeform.com`.
# SILK_IMAGE_HOST_ALLOWLIST=images.timeform.com
# Optional caps:
# SILK_IMAGE_MAX_BYTES=2097152
# SILK_IMAGE_FETCH_TIMEOUT_MS=12000
# Use in feeds / editor: RunnerSilks.imageUrl = "/api/silk-image?url=" + encodeURIComponent("https://cdn.../silk.png")
# or import silkImageProxyPath from @/app/features/render/silk-render-shared

# Puppeteer (scene PNG renders) — uses Google Chrome on macOS if installed; else bundled Chrome cache (~/.cache/puppeteer).
# If renders fail with "Could not find Chrome", run: npm run puppeteer:install
# PUPPETEER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# PUPPETEER_CACHE_DIR=

# FFmpeg — optional; code also auto-resolves via Homebrew paths + `command -v ffmpeg`
# Apple Silicon: /opt/homebrew/bin/ffmpeg  ·  Intel Homebrew: /usr/local/bin/ffmpeg
# FFMPEG_PATH=/opt/homebrew/bin/ffmpeg

# Optional: fixed dummy voice track instead of generated silence
# DUMMY_AUDIO_PATH=./assets/dummy/voice.mp3

# Supabase (Phase 2+ — ApiRacingDataProvider)
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
#
# RSS Import Builder (server): service role reads/writes feed tables. URL: SUPABASE_URL or NEXT_PUBLIC_SUPABASE_URL.
# SUPABASE_SERVICE_ROLE_KEY=
# Or save URL + service role in Admin → Provider keys → Supabase (same as other admin-stored secrets). (Shorts narration) — priority: ElevenLabs → OpenAI → macOS `say` → silent dummy
# OPENAI_API_KEY=
# Language Studio can use a separate model override. It also uses OPENAI_API_KEY.
# LANGUAGE_OPENAI_MODEL=gpt-4o-mini
# OPENAI_TTS_VOICE=nova
# OPENAI_TTS_MODEL=tts-1

# Language Studio translation provider (optional; OpenAI can run MVP without DeepL)
# DEEPL_API_KEY=
# DEEPL_API_URL=

# Cron endpoints. Set in production; use Authorization: Bearer <CRON_SECRET> for manual calls.
# CRON_SECRET=

# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_MODEL=eleven_multilingual_v2

# Runway ML (text-to-video in editor — https://dev.runwayml.com/ ; keys start with key_)
# RUNWAYML_API_SECRET=

# Live streaming — Restream (OAuth / distribution), Mux (owned live + playback), optional Livepeer
# Admin UI can store these in data/local/admin-settings.json instead.
# RESTREAM_CLIENT_ID=
# RESTREAM_CLIENT_SECRET=
# MUX_TOKEN_ID=
# MUX_TOKEN_SECRET=
# LIVEPEER_API_KEY=

# On macOS, built-in `say` runs when no keys above (natural free fallback). Disable with:
# USE_MACOS_SAY=0
# MACOS_SAY_VOICE=Samantha

# TEAMtalk News — optional: /api/teamtalk-feed and POST /api/teamtalk-import (tpl-* only; list is user + dummy)
# TEAMTALK_FEED_URL=https://www.teamtalk.com/mobile-app-feed
# TEAMTALK_FEED_ENABLED=0
