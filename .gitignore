# generated assets (keep folder, ignore outputs)
/output/*.json
/output/*.txt
/output/generated/
/output/uploads/
/output/images/*
/output/audio/*
/output/subtitles/*
/output/video/*
!/output/images/.gitkeep
!/output/images/library/
!/output/images/library/.gitkeep
/output/images/library/**
!/output/images/library/.gitkeep
!/output/audio/.gitkeep
!/output/subtitles/.gitkeep
!/output/video/.gitkeep

# Admin UI — local API keys (never commit)
/data/local/*
!/data/local/.gitkeep

# Local Netlify folder
.netlify
