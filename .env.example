# Dev server bind (optional). Default on macOS is :: (http://localhost + 127.0.0.1); elsewhere 0.0.0.0.
# Force IPv4-only: DEV_HOST=0.0.0.0  |  Loopback-only: DEV_HOST=127.0.0.1
# DEV_HOST=

# Dev file watching — `npm run dev` sets WATCHPACK_POLLING=true; next.config enables webpack poll(1s) unless disabled.
# WATCHPACK_POLLING=0
# NEXT_WEBPACK_POLL=0

# Admin UI (/admin) — required in production to POST saves; optional in development
# ADMIN_TOKEN=

# Plexa secure login. Required before public hosting.
# Generate with: openssl rand -base64 32
# PLEXA_SESSION_SECRET=
# Optional: protects first-admin setup in production.
# PLEXA_SETUP_TOKEN=
# Public host URL used when generating verification links, e.g. https://plexa.example.com
# PLEXA_PUBLIC_URL=

# Racing silks — proxy (recommended for Puppeteer + hotlink protection)
# Comma- or space-separated hostnames (no https://). Subdomains match: `timeform.com` allows `cdn.timeform.com`.
# SILK_IMAGE_HOST_ALLOWLIST=images.timeform.com
# Optional caps:
# SILK_IMAGE_MAX_BYTES=2097152
# SILK_IMAGE_FETCH_TIMEOUT_MS=12000
# Use in feeds / editor: RunnerSilks.imageUrl = "/api/silk-image?url=" + encodeURIComponent("https://cdn.../silk.png")
# or import silkImageProxyPath from @/app/features/render/silk-render-shared

# Puppeteer (scene PNG renders) — uses Google Chrome on macOS if installed; else bundled Chrome cache (~/.cache/puppeteer).
# If renders fail with "Could not find Chrome", run: npm run puppeteer:install
# PUPPETEER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# PUPPETEER_CACHE_DIR=

# FFmpeg — optional; code also auto-resolves via Homebrew paths + `command -v ffmpeg`
# Apple Silicon: /opt/homebrew/bin/ffmpeg  ·  Intel Homebrew: /usr/local/bin/ffmpeg
# FFMPEG_PATH=/opt/homebrew/bin/ffmpeg

# Optional: fixed dummy voice track instead of generated silence
# DUMMY_AUDIO_PATH=./assets/dummy/voice.mp3

# Supabase (Phase 2+ — ApiRacingDataProvider)
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
#
# RSS Import Builder — optional override if a publisher blocks the default browser-like UA
# RSS_BUILDER_USER_AGENT=Mozilla/5.0 ...

# RSS Import Builder (server): use project base URL only, e.g. https://YOUR_REF.supabase.co — do NOT append /rest/v1/
# SUPABASE_SERVICE_ROLE_KEY=
# Or save URL + service role in Admin → Provider keys → Supabase (same as other admin-stored secrets). (Shorts narration) — priority: ElevenLabs → OpenAI → macOS `say` → silent dummy
# OPENAI_API_KEY=
# DeepSeek (optional low-cost processing layer — OpenAI-compatible API)
# DEEPSEEK_API_KEY=
# DEFAULT_AI_PROVIDER=openai
# ENABLE_DEEPSEEK=false
# DEEPSEEK_MODEL=deepseek-chat
# Language Studio can use a separate model override. It also uses OPENAI_API_KEY.
# LANGUAGE_OPENAI_MODEL=gpt-4o-mini
# OPENAI_TTS_VOICE=nova
# OPENAI_TTS_MODEL=tts-1

# Language Studio translation provider (optional; OpenAI can run MVP without DeepL)
# DEEPL_API_KEY=
# DEEPL_API_URL=

# Cron endpoints. Set in production; use Authorization: Bearer <CRON_SECRET> for manual calls.
# CRON_SECRET=

# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_MODEL=eleven_multilingual_v2

# Runway ML (text-to-video in editor — https://dev.runwayml.com/ ; keys start with key_)
# RUNWAYML_API_SECRET=

# Higgsfield Cloud — Tools → AI Image Editor (server-only; never NEXT_PUBLIC_*)
# Prefer single line "key_id:key_secret", or separate variables (same as HF docs).
# HF_CREDENTIALS=
# HF_API_KEY=
# HF_API_SECRET=
# Optional: model path for Data Studio / Language Studio **prompt-only** image generation (default bytedance/seedream/v4/text-to-image).
# HIGGSFIELD_TEXT_TO_IMAGE_ENDPOINT=
# Optional resolution for Seedream (e.g. 1K, 2K).
# HIGGSFIELD_TEXT_TO_IMAGE_RESOLUTION=
# Optional model path on platform.higgsfield.ai (default: flux-pro/kontext/max/text-to-image)
# HIGGSFIELD_IMAGE_EDIT_ENDPOINT=

# Live streaming — Restream (OAuth / distribution), Mux (owned live + playback), optional Livepeer
# Admin UI can store these in data/local/admin-settings.json instead.
# RESTREAM_CLIENT_ID=
# RESTREAM_CLIENT_SECRET=
# MUX_TOKEN_ID=
# MUX_TOKEN_SECRET=
# LIVEPEER_API_KEY=

# On macOS, built-in `say` runs when no keys above (natural free fallback). Disable with:
# USE_MACOS_SAY=0
# MACOS_SAY_VOICE=Samantha

# TEAMtalk News — optional: /api/teamtalk-feed and POST /api/teamtalk-import (tpl-* only; list is user + dummy)
# TEAMTALK_FEED_URL=https://www.teamtalk.com/mobile-app-feed
# TEAMTALK_FEED_ENABLED=0

# SixLogics / consolidated fixture feed — use only in server routes (Data Studio proxy); never expose to the client bundle.
# SIXLOGICS_FIXTURE_BASE=https://datafeed.sixlogics.com/api
# Loop Feed — optional Authorization header for https://q.loop-feed.com/… topic content (Data Studio social context).
# Example: Bearer <token>   or   Token <token>
# LOOP_FEED_AUTHORIZATION=
# Calendar day for Loop Feed items vs selected date (IANA timezone applied to each post timestamp).
# LOOP_FEED_DAY_TZ=Europe/London

# OpenClaw MCP (Cursor automation — browser / Betway scrape via OpenClaw tools)
# Used by .cursor/mcp.json — do NOT commit real keys.
# OPENCLAW_MCP_URL=http://localhost:3721/mcp
# OPENCLAW_API_KEY=
# Remote gateway (stdio transport — optional second server "openclaw-local" in mcp.json):
# OPENCLAW_GATEWAY_URL=wss://your-openclaw-host:18789

# Next.js basePath for subpath deployments (e.g. /l). Must match next.config.ts. Client fetch() to /api/*
# must use this prefix — auth/forms use plexaAuthApiUrl / withAppPathPrefix (see app/lib/app-base-path.ts).
# NEXT_PUBLIC_BASE_PATH=/l

# Writable directory for Loop Feed JSON tool stores on serverless (defaults to TMPDIR/planetsport-studio/local when VERCEL, NETLIFY, or Lambda is detected).
# Point at a persistent mount if you need durability across instances (otherwise /tmp may reset).
# LOCAL_JSON_STORE_DIR=/var/task-mount/ps-studio-local

